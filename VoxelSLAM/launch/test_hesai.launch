<launch>
    <arg name="rviz" default="true" />

    <rosparam command="load" file="$(find voxel_slam)/config/hesai.yaml"/>
    <param name="finish" value="false"/>
    
    <!-- Create map folder if doesn't exist -->
    <param name="create_folder" value="true"/>
    
    <node pkg="voxel_slam" type="voxelslam" name="voxelslam" output="screen" launch-prefix="bash -c 'mkdir -p /home/mt-dhpyo-ubuntu/Data/map_storage/mappingtool_v2_data/open_dataset/hilti_multi/site1_handheld_5_test; exec $0 $@' -- " />
  
    <group if="$(arg rviz)">
        <node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find voxel_slam)/rviz_cfg/back.rviz" />
    </group>
     
</launch>